# Variables de entorno para los tests E2E con Playwright
# Copia este archivo a .env.test y rellena los valores reales

# URL del backoffice (por defecto localhost:3000)
TEST_BASE_URL=http://localhost:3000

# Credenciales de un usuario admin en Supabase (backoffice)
TEST_ADMIN_EMAIL=admin@grub.pe
TEST_ADMIN_PASSWORD=tu_contraseña_aqui
